# BigQuery
BQ_PROJECT_ID=mimetic-gravity-442013-u4
BQ_CREDENTIALS_PATH=/app/secrets/service_key.json

# Cube.js
CUBEJS_API_SECRET=change-me-32-byte-random
CUBEJS_DB_TYPE=bigquery
CUBEJS_DB_BQ_PROJECT_ID=${BQ_PROJECT_ID}
CUBEJS_DB_BQ_KEY_FILE=/cube/conf/service_key.json
CUBEJS_CACHE_AND_QUEUE_DRIVER=cubestore
CUBEJS_DEV_MODE=true
# Cube v1 default CUBEJS_SCHEMA_PATH is 'model'; this repo keeps legacy 'schema'.
CUBEJS_SCHEMA_PATH=schema

# Next.js
DATABASE_URL=postgres://app:devpass@postgres:5432/mkt_viz
REDIS_URL=redis://redis:6379
CUBE_API_URL=http://cube:4000/cubejs-api/v1
CUBE_API_SECRET=${CUBEJS_API_SECRET}

# AI provider — default is OpenAI gpt-5-nano (Responses API + structured output).
# Set AI_PROVIDER=claude to fall back to Anthropic (optional baseline).
AI_PROVIDER=openai
AI_MODEL=gpt-5-nano
OPENAI_API_KEY=sk-your-openai-key
# Optional Claude fallback — only read when AI_PROVIDER=claude.
CLAUDE_API_KEY=sk-ant-your-key
# DANGER: MOCK_AI=true (or legacy MOCK_CLAUDE=true) returns a fixed fixture
# from /api/ai/create-chart instead of calling a real provider. DEV ONLY.
# Remove once real provider keys are wired (see docs/status.md CRITICAL).
MOCK_AI=false
MOCK_CLAUDE=false
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-32-byte-random
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
ALLOWED_EMAIL_DOMAIN=dstrict.com
# DANGER: MOCK_AUTH=true enables password-less login for any @dstrict.com email.
# DEV ONLY. Never set true in staging/production.
# Task 3 S3 mock bypass — remove once real Google OAuth client is issued.
MOCK_AUTH=false

# Postgres
PG_USER=app
PG_PASSWORD=devpass
PG_DB=mkt_viz

# Sheets (AMNY/DSTX)
SHEET_ID=1WsATorbjts3CgjXKkNYW8iVs3ZKrnOkzcK4gHOIru50
SHEET_GSPREAD_ACCOUNT=gspread@skilled-keyword-423414-t0.iam.gserviceaccount.com
