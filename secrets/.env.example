# Optional local fallback (only when providers.*.allow_env_fallback=true)

# Meta Ads
FB_APP_ID=your_meta_app_id
FB_APP_SECRET=your_meta_app_secret
FB_ACCESS_TOKEN=your_meta_access_token
FB_AD_ACCOUNT_ID=act_123456789012345

# Google Ads
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_DEVELOPER_TOKEN=your_google_developer_token
GOOGLE_LOGIN_CUSTOMER_ID=1234567890

# TikTok Ads
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# Naver Ads
NAVER_API_KEY=your_naver_api_key
NAVER_SECRET_KEY=your_naver_secret_key
NAVER_CUSTOMER_ID=your_naver_customer_id
